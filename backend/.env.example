APP_NAME=Recruiter ATS
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true

# Postgres credentials used for local Docker setup. When running with
# docker-compose the hostname should be `postgres` (the service name).
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=recruiter_ai

# Docker-friendly DATABASE_URL that points to the postgres service.
# When running locally without Docker you may want to change the host
# to localhost instead of 'postgres'.
DATABASE_URL=postgresql+psycopg://postgres:postgres@postgres:5432/recruiter_ai

# OpenAI API key (required for resume parsing and fit scoring).
# Copy this file to .env and add your key there. Do NOT commit your key.
OPENAI_API_KEY=

# JWT settings
JWT_SECRET=change-me
ACCESS_TOKEN_EXPIRE_MINUTES=60
